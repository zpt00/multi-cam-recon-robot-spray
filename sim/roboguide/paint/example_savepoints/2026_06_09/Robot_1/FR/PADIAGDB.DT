!  rob_zdt_use  = 125;
!  rob_irdg_use = 126;
!
! CAUTION: When creating or adding parameters (specific to Equipment 2 with dualarm) an offset of 10 must be applied to the token
!          value for the token to be processed correctly.  This applies with PROCESS token (proc_io_type), CELL token (cell_io_type), 
!          and VAR tokens.
!
! Please see this example.
!CELL	PAVROPTN	byOptn[1].byOp[55]	1	PAVROPTN	byOptn[1].byOp[55]	1	PAVROPTN	cell_io_type
! Cell Digital Inputs Applicator Parameter Option (Memory-Mapped)
!1	1	73	0	0	28	73	1	Eq1:App Trig Tst	PAVRSHIO	tShioCmos[1].app_trig_di
