!  prof_sv_set  = 61;
!  rob_2ksp_use = 62;
!  aflw_chp_1ch = 63;
!  aflw_chp_2ch = 64;
!  rob_acch_use = 65;
!  rob_padg_use = 66;
!  rob_chmp_use = 67;
!  rob_hscd_use = 68;
!  spare        = 69;
!  rob_dsl_use  = 70;
!  rob_pnt_type = 71;
!  rob_wba_use  = 72;
