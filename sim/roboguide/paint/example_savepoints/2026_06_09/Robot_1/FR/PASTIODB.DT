! PaintTool I/O Auto Configurator Data File (PaStioDb.dt)	      
! This data file is used to Automatically configure the Standard I/O
! for PaintTool and any options that have been loaded.  This data
! file is a TAB-delimited file that can be edited With Microsoft
! Excel, Microsoft NotePad, Microsoft WordPad, or any editor that does
! not remove the TAB-delimited characters from this Database.
! Note: Microsoft Excel inserts bogus characters for two-dimensioal
! arrays, therefore, it is not a recommended editor!
! (example ins_to_par[1,1] will change to "ins_to_par[1,1]" resulting
! in an error when this file is processed!)
! Note: Comment lines may be inserted any place in this data file,
! either inside a TOKEN or outside outside of a TOKEN but both must
! start with the character (!) only!!!  This data file processes
! three tokens (CELL, PROCESS, and VAR) to setup Cell I/O,
! Process I/O, and Variables for PaintTool and any options, the
! following syntax is required:
! CELL  U.P.#1  U.V.#1  U.C.#1  U.P.#2  U.V.#2  U.C.#2  I.P.  I.V.
! where:
!	CELL - Instructs I/O Auto Configurator to assign Cell I/O
!	U.P.#1(User Program #1) - User program #1 name (KAREL or *SYSTEM*)
!	U.V.#1(User Variable #1) - User variable #1 name
!	U.C.#1(User Value #1) - User value #1 (This token is processed if
!                           variable #1 value = R-J3 variable)
!	U.P.#2(User Program #2) - User program #2 name (KAREL or *SYSTEM*)
!	U.V.#2(User Variable #2) - User variable #2 name
!	U.C.#2(User Value #2) - User value #2 (This token is processed if
!                           variable #2 value = R-J3 variable)
!	I.P.(Integer Program) - Integer program name (KAREL or *SYSTEM*)
!	I.V.(Integer Variable) - Integer variable name (PaintTool default
!                            is the following:
!
!                            Cell Hardware I/O Type [PAVROPTN]cell_io_type,
!                            user selects this at Controlled Start Menu)
!   where:
!     Supported Cell Hardware I/O Types (cell_io_type):
!       Any-Type I/O (no hardware checked, always assign this type) = 0
!       Memory-Mapped I/O					[PAVROPTN]cell_io_type = 1
!       Model A I/O (5 or 10 Slot Rack)		[PAVROPTN]cell_io_type = 2
!
!	Note:	All PLC interfaces selected will set the following parameter
!			to '9', therefore, the same section can be used to assign the
!			CELL I/O.  The variables, [PAVROPTN]plc_rack_no and plc_slot_no
!			are updated at the Controlled Start Tool Setup screen when one
!			of the following are selected!
!
!						Rack	Slot
!						----	----
!		FANUC I/O Link	0		1			[PAVROPTN]cell_io_type = 9
!       AB/Genius		16		1			[PAVROPTN]cell_io_type = 9
!      	ControlNet		85		1			[PAVROPTN]cell_io_type = 9
!       DeviceNet		81		1			[PAVROPTN]cell_io_type = 9
!       Interbus-S		71		1			[PAVROPTN]cell_io_type = 9
!       ProfiBus		67		1			[PAVROPTN]cell_io_type = 9
!
! PROCESS  U.P.#1  U.V.#1  U.C.#1  U.P.#2  U.V.#2  U.C.#2  I.P.  I.V.
! where:							
!	PROCESS - Instructs I/O Auto Configurator to assign Process I/O						
!	U.P.#1(User Program #1) - User program #1 name (KAREL or *SYSTEM*)
!	U.V.#1(User Variable #1) - User variable #1 name
!	U.C.#1(User Value #1) - User value #1 (This token is processed if
!                           variable #1 value = R-J3 variable)
!	U.P.#2(User Program #2) - User program #2 name (KAREL or *SYSTEM*)
!	U.V.#2(User Variable #2) - User variable #2 name
!	U.C.#2(User Value #2) - User value #2 (This token is processed if
!                           variable #2 value = R-J3 variable)
!	I.P.(Integer Program) - Integer program name (KAREL or *SYSTEM*)
!	I.V.(Integer Variable) - Integer variable name (PaintTool default
!                            is the following:
!
!                            Process Hardware I/O Type [PAVROPTN]proc_io_type,
!                            user selects this at Controlled Start Menu)
!	where:
!     Supported Process Hardware I/O Types (proc_io_type):
!       Any-Type I/O (no hardware checked, always assign this type) = 0
!       Memory-Mapped I/O    				[PAVROPTN]proc_io_type = 1
!       Model A I/O (5 Slot Rack #1)			[PAVROPTN]proc_io_type = 2
!       Model A I/O (5 Slot Rack #2)			[PAVROPTN]proc_io_type = 3
!       DeviceNet	     				[PAVROPTN]proc_io_type = 5
!
! VAR  U.P.#1  U.V.#1  U.C.#1  U.P.#2  U.V.#2  U.C.#2  I.P.  I.V.
! where:
!   VAR - Instructs I/O Auto Configurator to assign Variable						
!	U.P.#1(User Program #1) - User program #1 name (KAREL or *SYSTEM*)
!	U.V.#1(User Variable #1) - User variable #1 name
!	U.C.#1(User Value #1) - User value #1 (This token is processed if
!                           variable #1 value = R-J3 variable)
!	U.P.#2(User Program #2) - User program #2 name (KAREL or *SYSTEM*)
!	U.V.#2(User Variable #2) - User variable #2 name
!	U.C.#2(User Value #2) - User value #2 (This token is processed if
!                           variable #2 value = R-J3 variable)
!	I.P.(Integer Program) - Integer program name (KAREL or *SYSTEM*)
!	I.V.(Integer Variable) - Integer variable name (PaintTool default
!                            is the following:
!
!                            Applicator Types [PAVROPTN]which_gun,
!                            user selects this at Controlled Start Menu)
!   where:
!     Supported Applicator Types (which_gun):
!       Gun		    				[PAVROPTN]which_gun = 1
!       Bell(306)					[PAVROPTN]which_gun = 2
!       Bell(607)					[PAVROPTN]which_gun = 3
!
! The contents between CELL or PROCESS TOKEN and the STOPSECTION may
! contain only the following syntax, either a comment line (!) or an
! I/O assignment line as described below:
!
! *****NOTE:*****
! Please map any unused I/O that does not contain special logic in
! the KAREL code ( if dout[] <> 0 ) to DIN[1025] OR DOUT[1025]
! because these signals are already mapped to memory!!!
!
! I/O Type	LP Type	LP No.	Rack	Slot	PP Type	PP No.	Points	Comment	Program	Variable
! where:
!  I/O Type	This item is the Hardware I/O Type for this particular I/O
!           assignment line (CELL or PROCESS) as described above; if
!           this number is equal to the TOKEN Hardware I/O Type field,
!           OR if this item is set to '0', then this I/O assignment
!           line will be executed.
!  where:
!   Supported Cell Hardware I/O Types:
!     Any-Type I/O (no hardware checked, always assign this type) = 0
!     Memory-Mapped I/O	    			[PAVROPTN]cell_io_type = 1
!     Model A I/O (5 or 10 Slot Rack)		[PAVROPTN]cell_io_type = 2
!
!	Note:	All PLC interfaces selected will set the following parameter
!			to '9', therefore, the same section can be used to assign the
!			CELL I/O.  The variables, [PAVROPTN]plc_rack_no and plc_slot_no
!			are updated at the Controlled Start Tool Setup screen when one
!			of the following are selected!
!
!						Rack	Slot
!						----	----
!		FANUC I/O Link	0		1			[PAVROPTN]cell_io_type = 9
!       AB/Genius		16		1			[PAVROPTN]cell_io_type = 9
!      	ControlNet		85		1			[PAVROPTN]cell_io_type = 9
!       DeviceNet		81		1			[PAVROPTN]cell_io_type = 9
!       Interbus-S		71		1			[PAVROPTN]cell_io_type = 9
!       ProfiBus		67		1			[PAVROPTN]cell_io_type = 9
!
!   Supported Process Hardware I/O Types:
!     Any-Type I/O (no hardware checked, always assign this type) = 0
!     Memory-Mapped I/O						[PAVROPTN]proc_io_type = 1
!     Model A I/O (5 Slot Rack #1)				[PAVROPTN]proc_io_type = 2
!     Model A I/O (5 Slot Rack #2) 				[PAVROPTN]proc_io_type = 3
!     Model A I/O (10 Slot Rack #1 5 slots Cell - 5 slots Process)  [PAVROPTN]proc_io_type = 4
!     DeviceNet								[PAVROPTN]proc_io_type = 5
!
!  LP Type	This is the Logical Port Type field for the I/O assignment:
!  where:
!    1 -	Digital Input (DIN)
!    2 -	Digital Output (DOUT)
!    3 -	Analog Input (AIN)
!    4 -	Analog Output (AOUT)
!    6 -	PLC Digital Input (PI)
!    7 -	PLC Digital Output (PO)
!    8 -	Robot Digital Input (RDI)
!    9 -	Robot Digital Output (RDO)
!   11 -	Operator Panel Input (SOPIN)
!   12 -	Operator Panel Output (SOPOUT)
!   18 -	Group Digital Input (GPIN)
!   19 -	Group Digital Output (GPOUT)
!   20 -	User Operator Panel Input (UOPIN)
!   21 -	User Operator Panel Output (UOPOUT)
!
!  LP No.	This is the Logical Port Number field for the I/O assignment:		
!  where:
!    DIN	(1 - 256)
!    DOUT	(1 - 256)
!    AIN	(1 - 25)
!    AOUT	(1 - 25)
!    PI		(1 - 128)
!    PO		(1 - 128)
!    RDI	(1 - 8)
!    RDO	(1 - 8)
!    SOPIN	(1 - 15)
!    SOPOUT	(1 - 15)
!    GPIN	(1 - 25)
!    GPOUT	(1 - 25)
!    UOPIN	(1 - 20)
!    UOPOUT	(1 - 20)
!
!  Rack		This is the Rack number field for the I/O assignment:
!  where:
!    0 -	Memory-Mapped I/O or FANUC I/O Link
!    1 -	Cell Model A I/O (5 or 10 Slot Rack) or
!           Process Model A I/O (5 Slot Rack#1)
!    2 -	Process Model A I/O (5 Slot Rack#2)
!
!	Note:	The Rack number field for PLC I/O is ignored during processing,
!			the following is for reference ONLY!  The variable,
!			[PAVROPTN]plc_rack_no is updated at the Controlled Start Tool Setup
!			screen when one of the following are selected!
!
!	0  -	FANUC I/O Link
!   16 -	AB/Genius I/O
!   66 -	ProfiBus Master Mode
!   67 -	ProfiBus Slave Mode
!	70 -	Interbus-S Master Mode
!	71 -	Interbus-S Slave Mode
!   81 -	DeviceNet
!	85 -	ControlNet Channel #1 Mode
!	86 - 	ControlNet Channel #2 Mode
!
!  Slot		This is the Slot number field for the I/O assignment:
!  where:
!    0 -	Memory-Mapped I/O
!
!	Note:	The Slot number field for PLC I/O is ignored during processing,
!			the variable, [PAVROPTN]plc_slot_no is updated at the Controlled
!			Start Tool Setup screen when one of the above PLC interfaces is selected!
!
!    1 -	Physical cell or process module, AB/Genius, ControlNet, DeviceNet,
!           FANUC I/O Link, Interbus-S and ProfiBus
!    2 -	Physical cell or process module
!    3 -	Physical cell or process module
!    4 -	Physical cell or process module
!    5 -	Physical cell or process module
!    6 -	Physical cell or process module
!    7 -	Physical cell or process module
!    8 -	Physical cell or process module
!    9 -	Physical cell or process module
!   10 -	Physical cell or process module
!
!  PP Type	This is the Physical Port Type field for the I/O assignment:
!  where:
!    1 -	Digital Input (DIN)
!    2 -	Digital Output (DOUT)
!    3 -	Analog Input (AIN)
!    4 -	Analog Output (AOUT)
!   28 -	Memory Image BOOLEANS (DIN and DOUT)
!   29 -	Memory Image Numbers (GPIN, GPOUT, AIN, and AOUT)
!
!  PP No.	This is the Physical Port Type Number field for the I/O assignment:
!  where:
!    DIN	(1 - 256 only multiples of 8 are assigned)
!    DOUT	(1 - 256 only multiples of 8 are assigned)
!    AIN	(1 - 4 channels)
!    AOUT	(1 - 2 channels)
!    MEM_BOO_TYPE	(1 - 1024)
!    MEM_NUM_TYPE	(1 - 100)
!
!  Points	This is the Points field for the I/O assignment:
!  where:
!    1 -	DIN, DOUT, AIN, AOUT, MEM_BOO_TYPE, MEM_NUM_TYPE
!    1 - ?	GPIN AND GPOUT to physical number of points on module
!
!  Comment	This is the Comment field for the I/O assignment which is
!           an optional field.
!
!  Program	This is the Program name field for the I/O assignment
!           which is an optional field.
!
!  Note:	This program must be a valid KAREL program loaded on the
!           controller or specify *SYSTEM*.
!
!  Variable	This is the Variable name field for the I/O assignment
!           which is an optional field.
!
!  Note:	This variable will be set to the value of the
!           Logical Port Number (LP No.) field if this is a valid
!           KAREL program variable or *SYSTEM* variable.
!
! The contents between the VAR TOKEN and the STOPSECTION may contain
! only the following syntax, either a comment line (!) or a variable
! assignment line as described below:
!
! User Integer  Data Type  Program  Variable  Value
! where:				
!  User Integer	This is the User Integer field that contains a
!               specified value used to compare against the Integer
!               Variable defined in the VAR TOKEN.  PaintTool defaults
!               this Integer Variable to [PAVROPTN]which_gun with the
!               following configurations:
!  where:
!    0 -	Any Applicator Type		
!    1 -	Gun
!    2 -	Bell(306)
!    3 -	Bell(607)
!
!  Data Type	This is the Data Type field with the following types
!               supported:
!  where:
!    BOOLEAN	Can specify 0, 1, FALSE, or TRUE
!    BYTE		Whole numbers from 1 to 255
!    SHORT		Whole numbers from 1 to 32767
!    INTEGER	Whole numbers from -2,147,483,648 to 2,147,483,647
!    REAL		Fraction numbers from 10xy-38 to 10xy38
!    STRING		Character expressions from 1 to 80 characters
!
!  Program		This is the Program name field which must contain a
!               valid KAREL program name loaded onto the controller or
!               *SYSTEM*.
!
!  Variable		This is the Variable name field which must contain a
!               valid KAREL program variable loaded onto the controller
!               or *SYSTEM*.
!
!  Value		This is the Value field which is the value that the
!               above specified variable will be assigned.
!
!  NOTE: The following constants are defined in PAVROPPR.EDD to represent the array index
!        element into the new [PAVROPTN]byOptn[1..MAX_NUM_GRPS].byOp[MAX_OPS] OF BYTE data type to conserve memory
!        for boolean data type operations in PaintTool!
!  ConvSyncOpt  = 1;
!  job_que_rep  = 2;
!  job_ent_tp   = 3;  
!  job_strt_sg  = 4;
!  job_clr_que  = 5;
!  job_in_que   = 6;
!  pushout_req  = 7;
!  pamnent_clr  = 8;
!  rob_cc_use   = 9;
!  rob_accu_use = 10;
!  rob_dq_set   = 11;
!  rob_cc_set   = 12;
!  rob_last_use = 13;
!  rob_auto_out = 14;
!  CPXType = 15 (0 = Non-P-500, 
!                1 = CPX-MPA-1K/IC, 
!                2 = CPX-MPA-2K, 
!                3 = CPX-MPA-Simple2K)
!  rob_ac_use   = 16;
!  rob_ac_set   = 17;
!  rob_ac2_use  = 18;
!  rob_ln_use   = 19;
!  rob_ln_set   = 20;
!  rob_rl_use   = 21;
!  rob_rl_set   = 22;
!  rob_jog_pn   = 23;
!  AutoTCPUpd   = 24;
!  rob_eip_use  = 25;
!  rob_canc_use = 26;
!  rob_que_use  = 27;
!  rob_cq_use   = 28;
!  rob_op_use   = 29;
!  rob_mov_home = 30;
!  rob_op_type  = 31;
!  rob_ae_use   = 32;
!  rob_2gun_use = 33;
!  rob_2fg_use  = 34;
!  rob_mt_use   = 35;
!  rob_mtap_use = 36;
!  rob_prst_use = 37;
!  rob_func_use = 38;
!  UserTP_use   = 39;
!  rob_ipc_use  = 40;
!  rob_2kgn_use = 41;
!  rob_mtr_use  = 42;
!  rob_aa_use   = 43;
!  rob_ts_use   = 44;
!  bLimitTurns  = 45;
!  rob_tper_use = 46;
!  dm_auto_res  = 47;
!  force_use    = 48;
!  rob_bell_use = 49;
!  rob_607_use  = 50;
!  rob_stio_use = 51;
!  rob_stio_set = 52;
!  rob_enio_use = 53;
!  rob_enio_set = 54;
!  rob_parm_use = 55;
!  rob_trk_use  = 56;
!  rob_ethr_set = 57;
!  rob_dnet_use = 58;
!  dnet_sv_set  = 59;
!  rob_prof_use = 60;
!  prof_sv_set  = 61;
!  rob_2ksp_use = 62;
!  aflw_chp_1ch = 63;
!  aflw_chp_2ch = 64;
!  rob_acch_use = 65;
!  rob_padg_use = 66;
!  rob_chmp_use = 67;
!  rob_hscd_use = 68;
!  spare        = 69;
!  rob_dsl_use  = 70;
!  rob_pnt_type = 71;
!  rob_wba_use  = 72;
!  rob_sba_use  = 73;
!  rob_dq_use   = 74;
!  rob_dual_arm = 75;
!  AppEnabTch  = 76;
!  AppEnbTstRun   = 77;
!  prst_by_job  = 78;
!  rob_zone_use = 79;
!  rob_2kgn_set = 80;
!  rob_accu_set = 81;
!  rob_ipc_set  = 82;
!  rob_parm_set = 83;
!  rob_main_set = 84;
!  rob_trk_set  = 85;
!  MskSpeedMsg  = 86;
!  BrakeRelUse  = 87;
!  hiresaout    = 88;
!  hondaevb_use = 89;
!  SMCNodeCfg   = 90;
!  spare        = 91;
!  SolvAir_use  = 92;
!  rob_pmc_use  = 93;
!  rob_pmc_set  = 94;
!  rob_es_use   = 95;
!  ISTP        = 96;
!  rob_ppro_use = 97;
!  Sames_USE    = 98;
!  rob_virt_use = 99;
!  spare        = 100;
!  rob_ic_use   = 101;
!  rob_ff_use   = 102;
!  rob_p500_mnt = 103;
!  rob_mcro_use = 104;
!  CellNumCntr  = 105;
!  RosIpUse     = 106;
!  ArmNumber    = 107;
!  spare        = 108;
!  rob_svhk_use = 109;
!  rob_vis_use  = 110;
!  rob_mate_use = 111;
!  rob_mate_set = 112;
!  old_trig_use = 113;
!  rob_aa_set   = 114;
!  rob_clr_use  = 115;
!  rob_ichk_use = 116;
!  rob_rvrs_ufm = 117;
!  rob_eenc_use = 118;
!  rob_pwrf_use = 119;
!  rob_sync_use = 120;
!  rob_aseq_use = 121;
!  rob_sync_frc = 122;
!  rob_tfrm_use = 123;
!  rob_zdt_use  = 125;
!  rob_irdg_use = 126;
!
! Start Data File TOKENS

!rob_stio_use = 51
CELL	PAVROPTN	byOptn[1].byOp[51]	1	PAVROPTN	byOptn[1].byOp[51]	1	PAVROPTN	cell_io_type
